{
  "name": "vcc-directory",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:init": "wrangler d1 execute vcc-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute vcc-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "wrangler": "^4.87.0",
    "typescript": "^5.8.0"
  }
}
