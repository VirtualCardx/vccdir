{
	"name": "vcc-directory",
	"main": "src/index.tsx",
	"compatibility_date": "2025-04-30",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"ADMIN_PASSWORD": "change-me-in-production"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "vcc-db",
			"database_id": "659dabde-5d75-41a8-a71c-85042e8145a2"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "vcc-logos"
		}
	]
}