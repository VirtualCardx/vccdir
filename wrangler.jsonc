{
	"name": "vcc-directory",
	"main": "src/index.tsx",
	"compatibility_date": "2025-04-30",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"ADMIN_PASSWORD": "change-me-in-production",
		"SESSION_SECRET": "change-me-in-production",
		"HERMES_API_TOKEN": "change-me-in-production",
		"SITE_URL": "https://vccdir.com"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "vcc-db",
			"database_id": "760e2ce1-d7b0-4d14-bac9-af786bd88a8c"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "vcc-logos"
		}
	]
}
